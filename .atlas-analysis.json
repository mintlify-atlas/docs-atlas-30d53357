  "keyFeatures": [
    "DMX512 control via video streaming with Artnet Grid Node",
    "AudioLink integration for audio-reactive lighting",
    "Hardware-accelerated shader-based lighting system",
    "Moving lights with pan/tilt control and gobo projection",
    "Static lights including PAR, blinder, flasher, and lightbar",
    "Lasers and disco ball effects",
    "Local UI control panel for per-user brightness adjustment",
    "Unity Editor tools for DMX patch management and fixture definitions",
    "VRChat UdonSharp scripts for dynamic control",
    "Optimized for VR performance with GPU instancing"
  ],
